<% content_for(:title, "Accept Invitation") %>

<section class="form-card">
  <h1>Join <%= @invitation.company.name %></h1>
  <p class="form-card__subtitle">
    <%= @invitation.inviter.email_address %> invited you to join as a <%= @invitation.role %>.
  </p>

  <% if authenticated? %>
    <%# Logged-in user: just accept %>
    <%= button_to "Accept Invitation", invitation_acceptance_path(token: @invitation.token), method: :patch, class: "btn btn--primary" %>
  <% else %>
    <%# New user: create account and accept %>
    <p class="form-card__info">Create your account to join the team.</p>

    <%= form_with(url: invitation_acceptance_path(token: @invitation.token), method: :patch, class: "form") do |f| %>
      <% if defined?(@user) && @user&.errors&.any? %>
        <div class="form__errors" role="alert">
          <% @user.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form__field">
        <%= f.label :email_address, "Email" %>
        <%= f.email_field :email_address, value: @invitation.email_address, readonly: true %>
      </div>

      <div class="form__field">
        <%= f.label :password %>
        <%= f.password_field :password, required: true %>
      </div>

      <div class="form__field">
        <%= f.label :password_confirmation, "Confirm password" %>
        <%= f.password_field :password_confirmation, required: true %>
      </div>

      <div class="form__actions">
        <%= f.submit "Create account & join", class: "btn btn--primary" %>
      </div>
    <% end %>

    <p class="form-card__footer">
      Already have an account? <%= link_to "Log in", new_session_path %> first, then click the invitation link again.
    </p>
  <% end %>
</section>
