<% content_for :title, "Notifications" %>

<div class="page-header">
  <h1>Notifications</h1>
  <% if @notifications.any? %>
    <%= button_to "Mark all read", mark_all_read_notifications_path, method: :post, class: "btn btn--ghost btn--sm" %>
  <% end %>
</div>

<div class="notifications-list">
  <% if @notifications.any? %>
    <% @notifications.each do |notification| %>
      <%= render "notification", notification: notification %>
    <% end %>
  <% else %>
    <p class="notification-dropdown__empty">No notifications yet.</p>
  <% end %>
</div>
