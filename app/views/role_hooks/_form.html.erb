<%= form_with(model: [ @role, role_hook ], class: "form") do |f| %>
  <% if role_hook.errors.any? %>
    <div class="form__errors" role="alert">
      <% role_hook.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :name, "Hook name" %>
    <%= f.text_field :name, autofocus: true, placeholder: "e.g. Validation by QA Role, Notify Slack" %>
  </div>

  <div class="form__field">
    <%= f.label :lifecycle_event, "Lifecycle event" %>
    <%= f.select :lifecycle_event, lifecycle_event_options, { include_blank: "Select event..." }, { class: "form__select", required: true } %>
    <p class="form__hint">When should this hook fire?</p>
  </div>

  <div class="form__field">
    <%= f.label :action_type, "Action type" %>
    <%= f.select :action_type, action_type_options, { include_blank: "Select action..." }, { class: "form__select", required: true } %>
    <p class="form__hint">What should happen when the hook fires?</p>
  </div>

  <fieldset class="form__fieldset">
    <legend>Action Configuration</legend>

    <div class="form__field">
      <%= label_tag "role_hook_action_config_target_role_id", "Target role (for trigger_role hooks)" %>
      <%= select_tag "role_hook[action_config][target_role_id]",
            options_from_collection_for_select(
              Current.project.roles.active.excluding_subtree(@role).order(:title),
              :id, :title,
              role_hook.action_config&.dig("target_role_id")&.to_i
            ),
            include_blank: "Select role...",
            class: "form__select",
            id: "role_hook_action_config_target_role_id" %>
      <p class="form__hint">The role that will be triggered to validate work. Required for trigger_role hooks.</p>
    </div>

    <div class="form__field">
      <%= label_tag "role_hook_action_config_prompt", "Validation prompt (optional)" %>
      <%= text_area_tag "role_hook[action_config][prompt]",
            role_hook.action_config&.dig("prompt"),
            rows: 3,
            placeholder: "Review the completed work for correctness and quality.",
            id: "role_hook_action_config_prompt" %>
    </div>

    <div class="form__field">
      <%= label_tag "role_hook_action_config_url", "Webhook URL (for webhook hooks)" %>
      <%= text_field_tag "role_hook[action_config][url]",
            role_hook.action_config&.dig("url"),
            placeholder: "https://hooks.example.com/notify",
            id: "role_hook_action_config_url" %>
      <p class="form__hint">The URL to POST to when the hook fires. Required for webhook hooks.</p>
    </div>
  </fieldset>

  <div class="form__field">
    <%= f.label :enabled, "Enabled" %>
    <div class="form__toggle">
      <%= f.check_box :enabled, class: "form__checkbox" %>
      <span class="form__toggle-label">Hook is active and will fire on matching events</span>
    </div>
  </div>

  <div class="form__field">
    <%= f.label :position, "Position (execution order)" %>
    <%= f.number_field :position, min: 0, step: 1, class: "form__input--narrow" %>
    <p class="form__hint">Lower position numbers fire first. Hooks with the same position fire in creation order.</p>
  </div>

  <div class="form__actions">
    <%= f.submit class: "btn btn--primary" %>
    <%= link_to "Cancel",
          role_hook.persisted? ? role_role_hook_path(@role, role_hook) : role_role_hooks_path(@role),
          class: "btn btn--ghost" %>
  </div>
<% end %>
