<% content_for(:title, "Hooks - #{@role.title}") %>

<section class="hooks-page">
  <div class="hooks-page__header">
    <div>
      <h1>Hooks</h1>
      <p class="hooks-page__subtitle">
        <%= link_to @role.title, @role %> &rsaquo; Hooks
      </p>
    </div>
    <%= link_to "New Hook", new_role_role_hook_path(@role), class: "btn btn--primary btn--sm" %>
  </div>

  <% if @role_hooks.any? %>
    <div class="hooks-list">
      <% @role_hooks.each do |role_hook| %>
        <%= render partial: "role_hooks/role_hook", locals: { role_hook: role_hook } %>
      <% end %>
    </div>
  <% else %>
    <div class="hooks-page__empty">
      <p>No hooks configured for <%= @role.title %>.</p>
      <p>Hooks fire automatically when tasks change status, enabling role-to-role validation and webhook integrations.</p>
      <%= link_to "Create first hook", new_role_role_hook_path(@role), class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
