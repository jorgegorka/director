<% content_for(:title, "Audit Log") %>

<section class="audit-log-page">
  <div class="audit-log-page__header">
    <h1>Audit Log</h1>
    <p class="audit-log-page__subtitle">All actions recorded across <%= Current.project.name %></p>
  </div>

  <%= render "audit_logs/filters" %>

  <% if @index.any_events? %>
    <table class="audit-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Action</th>
          <th>Actor</th>
          <th>Target</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <%= render partial: "audit_logs/event_row", collection: @index.events, as: :event %>
      </tbody>
    </table>

    <% if @index.events.size >= 100 %>
      <p class="audit-log-page__note">Showing the 100 most recent events. Use filters to narrow results.</p>
    <% end %>
  <% else %>
    <div class="audit-log-page__empty">
      <p>No audit events found<%= " matching your filters" if @index.filtered? %>.</p>
    </div>
  <% end %>
</section>
