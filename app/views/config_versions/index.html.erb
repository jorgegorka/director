<% content_for(:title, "Version History") %>

<section class="versions-page">
  <div class="versions-page__header">
    <h1>Version History</h1>
    <p class="versions-page__subtitle">
      <%= @versionable_type %> "<%= @versionable.try(:title) || @versionable.try(:name) %>"
      &mdash;
      <%= link_to "Back to #{@versionable_type.downcase}", @versionable %>
    </p>
  </div>

  <% if @versions.any? %>
    <table class="table versions-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Action</th>
          <th>Author</th>
          <th>Changes</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <%= render partial: "config_versions/version_row", collection: @versions, as: :version %>
      </tbody>
    </table>
  <% else %>
    <div class="versions-page__empty">
      <p>No version history recorded yet. Versions are created when governance-relevant attributes are changed.</p>
    </div>
  <% end %>
</section>
