<% if can_escalate?(task) %>
  <div class="task-action-form">
    <h3>Escalate to Manager</h3>
    <p class="task-action-form__target">Will escalate to: <strong><%= escalation_target_name(task) %></strong></p>
    <%= form_with(url: escalate_task_path(task), class: "form form--inline") do |f| %>
      <div class="form__field form__field--inline">
        <%= f.text_field :reason, placeholder: "Reason (optional)" %>
        <%= f.submit "Escalate", class: "btn btn--ghost btn--sm" %>
      </div>
    <% end %>
  </div>
<% end %>
