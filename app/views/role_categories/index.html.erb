<% content_for(:title, "Role Categories") %>

<section class="role-categories-page">
  <div class="role-categories-page__header">
    <h1>Role Categories</h1>
    <%= link_to "New Category", new_role_category_path, class: "btn btn--primary btn--sm" %>
  </div>

  <% if @role_categories.any? %>
    <div class="role-categories-list">
      <% @role_categories.each do |category| %>
        <div class="role-category-card">
          <div class="role-category-card__header">
            <%= link_to category.name, category, class: "role-category-card__title" %>
            <span class="role-category-card__count"><%= category.roles.size %> <%= "role".pluralize(category.roles.size) %></span>
          </div>
          <% if category.description.present? %>
            <p class="role-category-card__description"><%= category.description %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="role-categories-page__empty">
      <p>No role categories yet. Create your first category to classify your roles.</p>
      <%= link_to "Create a category", new_role_category_path, class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
