<% content_for(:title, @role_category.name) %>

<section class="role-category-detail">
  <header class="role-category-detail__profile">
    <div class="role-category-detail__profile-main">
      <h1 class="role-category-detail__name"><%= @role_category.name %></h1>
      <% if @role_category.description.present? %>
        <p class="role-category-detail__description"><%= @role_category.description %></p>
      <% end %>
    </div>
    <div class="role-category-detail__actions">
      <%= link_to "Edit", edit_role_category_path(@role_category), class: "btn btn--ghost btn--sm" %>
      <%= button_to "Delete", @role_category, method: :delete, class: "btn btn--ghost btn--sm role-category-detail__delete",
            data: { turbo_confirm: "Delete #{@role_category.name}? This will fail if roles are assigned to it." } %>
    </div>
  </header>

  <div class="role-category-detail__grid">
    <div class="role-category-detail__primary">
      <div class="role-category-detail__card">
        <h2 class="role-category-detail__card-title">Job Specification</h2>
        <div class="role-category-detail__job-spec">
          <%= simple_format(@role_category.job_spec) %>
        </div>
      </div>
    </div>

    <div class="role-category-detail__sidebar">
      <div class="role-category-detail__card">
        <h2 class="role-category-detail__card-title">Assigned Roles (<%= @roles.size %>)</h2>
        <% if @roles.any? %>
          <ul class="role-category-detail__roles-list">
            <% @roles.each do |role| %>
              <li>
                <span class="role-card__status-dot role-card__status-dot--<%= role.status %>"></span>
                <%= link_to role.title, role %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="role-category-detail__empty-note">No roles assigned to this category.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>
