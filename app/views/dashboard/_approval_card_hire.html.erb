<div class="approval-card">
  <div class="approval-card__info">
    <span class="approval-card__title"><%= link_to pending_hire.role.title, role_path(pending_hire.role) %> wants to hire</span>
    <span class="approval-card__detail"><%= pending_hire.template_role_title %> &mdash; Budget: $<%= "%.2f" % (pending_hire.budget_cents / 100.0) %>/mo</span>
    <span class="approval-card__time"><%= time_ago_in_words(pending_hire.created_at) %> ago</span>
  </div>
  <div class="approval-card__actions">
    <%= button_to "Approve", role_approval_path(pending_hire.role), class: "btn btn--primary btn--sm",
          data: { turbo_confirm: "Approve hiring #{pending_hire.template_role_title}?" } %>
    <%= button_to "Reject", role_approval_path(pending_hire.role), method: :delete, class: "btn btn--danger btn--sm",
          data: { turbo_confirm: "Reject hiring #{pending_hire.template_role_title}?" } %>
  </div>
</div>
