<div class="kanban-card"
     id="kanban-task-<%= task.id %>"
     draggable="true"
     data-kanban-target="card"
     data-task-id="<%= task.id %>"
     data-action="dragstart->kanban#dragStart dragend->kanban#dragEnd">
  <div class="kanban-card__title">
    <%= link_to task.title, task_path(task) %>
  </div>
  <% if task.parent_task.present? %>
    <span class="kanban-card__parent">Subtask of <%= link_to task.parent_task.title, task_path(task.parent_task) %></span>
  <% end %>
  <div class="kanban-card__meta">
    <%= task_priority_badge(task) %>
    <% if task.assignee.present? %>
      <span class="kanban-card__assignee"><%= task.assignee.title %></span>
    <% else %>
      <span class="kanban-card__unassigned">Unassigned</span>
    <% end %>
    <% if task.cost_cents.present? %>
      <span class="kanban-card__cost"><%= format_cents_as_dollars(task.cost_cents) %></span>
    <% end %>
  </div>
</div>
