<div class="approval-card">
  <div class="approval-card__info">
    <span class="approval-card__title"><%= link_to task.title, task_path(task), data: { turbo_frame: "_top" } %></span>
    <span class="approval-card__detail">
      <% if task.assignee %>
        Submitted by <%= task.assignee.title %>
      <% end %>
      <% if task.creator %>
        &middot; Created by <%= task.creator.title %>
      <% end %>
    </span>
    <span class="approval-card__time"><%= time_ago_in_words(task.updated_at) %> ago</span>
  </div>
  <div class="approval-card__actions">
    <%= button_to "Approve", approve_task_path(task), class: "btn btn--primary btn--sm",
          data: { turbo_confirm: "Approve '#{task.title}'?" } %>
    <%= button_to "Reject", reject_task_path(task), class: "btn btn--danger btn--sm",
          data: { turbo_confirm: "Reject '#{task.title}'?" } %>
    <%= link_to "Review", task_path(task), class: "btn btn--ghost btn--sm", data: { turbo_frame: "_top" } %>
  </div>
</div>
