<% content_for(:title, "Dashboard") %>
<section class="dashboard" data-controller="tabs">
  <%= turbo_stream_from "dashboard_company_#{Current.company.id}" %>
  <div class="dashboard__header">
    <div>
      <h1><%= @overview.company.name %></h1>
      <p class="dashboard__subtitle">Company command center</p>
    </div>
    <div class="dashboard-quick-links">
      <%= link_to "Org Chart", org_chart_path, class: "btn btn--ghost btn--sm" %>
      <%= link_to "Goals", goals_path, class: "btn btn--ghost btn--sm" %>
      <%= link_to "Audit Log", audit_logs_path, class: "btn btn--ghost btn--sm" %>
    </div>
  </div>

  <% if @overview.show_mission? %>
    <div class="dashboard-mission">
      <div class="dashboard-mission__info">
        <span class="dashboard-mission__label">Mission</span>
        <%= link_to @overview.mission.title, goal_path(@overview.mission), class: "dashboard-mission__title" %>
      </div>
      <div class="dashboard-mission__progress">
        <% percentage = @overview.mission.completion_percentage %>
        <%= render "shared/progress_bar", percentage: percentage %>
        <span class="dashboard-mission__pct"><%= percentage %>%</span>
      </div>
    </div>
  <% end %>

  <nav class="dashboard-tabs" role="tablist">
    <%= link_to "Overview", dashboard_path,
        class: "dashboard-tab dashboard-tab--active",
        data: { turbo_frame: "tab_content", action: "click->tabs#activate", tabs_target: "tab" } %>
    <%= link_to "Tasks", dashboard_tasks_path,
        class: "dashboard-tab",
        data: { turbo_frame: "tab_content", action: "click->tabs#activate", tabs_target: "tab" } %>
    <%= link_to "Activity", dashboard_activities_path,
        class: "dashboard-tab",
        data: { turbo_frame: "tab_content", action: "click->tabs#activate", tabs_target: "tab" } %>
  </nav>

  <%= turbo_frame_tag "tab_content", target: "_top" do %>
    <%= render "dashboard/overview_tab" %>
  <% end %>
</section>
