<% content_for(:title, "Dashboard") %>
<section class="dashboard" data-controller="tabs" data-tabs-active-tab-value="<%= params[:tab] || "overview" %>">
  <%= turbo_stream_from "dashboard_company_#{Current.company.id}" %>
  <div class="dashboard__header">
    <div>
      <h1><%= @company.name %></h1>
      <p class="dashboard__subtitle">Company command center</p>
    </div>
    <div class="dashboard-quick-links">
      <%= link_to "Org Chart", org_chart_path, class: "btn btn--ghost btn--sm" %>
      <%= link_to "Goals", goals_path, class: "btn btn--ghost btn--sm" %>
      <%= link_to "Audit Log", audit_logs_path, class: "btn btn--ghost btn--sm" %>
    </div>
  </div>

  <% if @mission %>
    <div class="dashboard-mission">
      <div class="dashboard-mission__info">
        <span class="dashboard-mission__label">Mission</span>
        <%= link_to @mission.title, goal_path(@mission), class: "dashboard-mission__title" %>
      </div>
      <div class="dashboard-mission__progress">
        <% percentage = @mission.completion_percentage %>
        <%= render "shared/progress_bar", percentage: percentage %>
        <span class="dashboard-mission__pct"><%= percentage %>%</span>
      </div>
    </div>
  <% end %>

  <nav class="dashboard-tabs" role="tablist">
    <button class="dashboard-tab"
            data-tabs-target="tab" data-tab="overview"
            data-action="click->tabs#switch" role="tab">
      Overview
    </button>
    <button class="dashboard-tab"
            data-tabs-target="tab" data-tab="tasks"
            data-action="click->tabs#switch" role="tab">
      Tasks
    </button>
    <button class="dashboard-tab"
            data-tabs-target="tab" data-tab="activity"
            data-action="click->tabs#switch" role="tab">
      Activity
    </button>
  </nav>

  <div data-tabs-target="panel" data-tab-name="overview">
    <%= render "dashboard/overview_tab" %>
  </div>
  <div data-tabs-target="panel" data-tab-name="tasks" hidden>
    <%= render "dashboard/tasks_tab" %>
  </div>
  <div data-tabs-target="panel" data-tab-name="activity" hidden>
    <%= render "dashboard/activity_tab" %>
  </div>
</section>
