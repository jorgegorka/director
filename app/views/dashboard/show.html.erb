<% content_for(:title, "Dashboard") %>
<section class="dashboard">
  <%= turbo_stream_from "dashboard_company_#{Current.company.id}" %>
  <div class="dashboard__header">
    <div>
      <h1><%= @overview.company.name %></h1>
      <p class="dashboard__subtitle">Company command center</p>
    </div>
  </div>

  <% if @overview.top_goal %>
    <div class="dashboard-mission">
      <div class="dashboard-mission__info">
        <span class="dashboard-mission__label">Goal</span>
        <%= link_to @overview.top_goal.title, goal_path(@overview.top_goal), class: "dashboard-mission__title" %>
      </div>
      <div class="dashboard-mission__progress">
        <% percentage = @overview.top_goal.completion_percentage %>
        <%= render "shared/progress_bar", percentage: percentage %>
        <span class="dashboard-mission__pct"><%= percentage %>%</span>
      </div>
    </div>
  <% end %>

  <nav class="dashboard-tabs" role="tablist">
    <%= link_to "Overview", dashboard_path,
        class: "dashboard-tab #{"dashboard-tab--active" if @current_tab == :overview}" %>
    <%= link_to "Tasks", dashboard_tasks_path,
        class: "dashboard-tab #{"dashboard-tab--active" if @current_tab == :tasks}" %>
    <%= link_to "Activity", dashboard_activities_path,
        class: "dashboard-tab #{"dashboard-tab--active" if @current_tab == :activities}" %>
    <%= link_to dashboard_approvals_path,
        class: "dashboard-tab #{"dashboard-tab--active" if @current_tab == :approvals}" do %>
      Approvals
      <%= render "dashboard/approvals_badge", count: @approvals_count %>
    <% end %>
  </nav>

  <% tab_partials = { overview: "overview", tasks: "tasks", activities: "activity", approvals: "approvals" } %>
  <%= render "dashboard/#{tab_partials[@current_tab]}_tab" %>
</section>
