<% content_for(:title, "Heartbeat History - #{@role.title}") %>

<section class="heartbeats-history">
  <header class="heartbeats-history__header">
    <div>
      <h1>Heartbeat History</h1>
      <p class="heartbeats-history__subtitle">
        <%= link_to @role.title, role_path(@role) %> &mdash;
        <%= @total_count %> total events
      </p>
    </div>
    <%= link_to "Back to Role", role_path(@role), class: "btn btn--ghost btn--sm" %>
  </header>

  <% if @heartbeat_events.any? %>
    <div class="heartbeats-history__card">
      <table class="table heartbeat-table heartbeat-table--full">
        <thead>
          <tr>
            <th>Trigger</th>
            <th>Status</th>
            <th>Source</th>
            <th>Delivered</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <%= render partial: "heartbeats/event_row", collection: @heartbeat_events, as: :event, locals: { show_delivered: true } %>
        </tbody>
      </table>
    </div>

    <% if @total_pages > 1 %>
      <nav class="pagination" aria-label="Heartbeat history pages">
        <% if @current_page > 1 %>
          <%= link_to "Previous", role_heartbeats_path(@role, page: @current_page - 1), class: "btn btn--ghost btn--sm" %>
        <% end %>
        <span class="pagination__info">Page <%= @current_page %> of <%= @total_pages %></span>
        <% if @current_page < @total_pages %>
          <%= link_to "Next", role_heartbeats_path(@role, page: @current_page + 1), class: "btn btn--ghost btn--sm" %>
        <% end %>
      </nav>
    <% end %>
  <% else %>
    <div class="heartbeats-history__empty">
      <p>No heartbeat events recorded yet.</p>
      <p>Events will appear here when the role is triggered by:</p>
      <ul>
        <li>Scheduled heartbeat (configure in role settings)</li>
        <li>Task assigned to this role</li>
        <li>@mention in a task conversation</li>
      </ul>
    </div>
  <% end %>
</section>
