<tr class="heartbeat-row heartbeat-row--<%= event.status %>">
  <td><%= heartbeat_trigger_badge(event) %></td>
  <td><%= heartbeat_status_indicator(event) %></td>
  <td><%= event.trigger_source || "—" %></td>
  <% if local_assigns[:show_delivered] %>
    <td>
      <% if event.delivered_at %>
        <%= time_ago_in_words(event.delivered_at) %> ago
      <% else %>
        &mdash;
      <% end %>
    </td>
  <% end %>
  <td><%= time_ago_in_words(event.created_at) %> ago</td>
</tr>
