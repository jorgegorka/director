<fieldset class="form__fieldset form__fieldset--gates">
  <legend>Approval Gates</legend>
  <p class="form__hint">Select which actions require human approval before this role can proceed.</p>
  <%# Hidden field signals that the gate section was submitted (handles all-unchecked case) %>
  <input type="hidden" name="role[gates_submitted]" value="1">
  <div class="gate-checkboxes">
    <% ApprovalGate::GATABLE_ACTIONS.each do |action_type| %>
      <% gate = role.approval_gates.find { |g| g.action_type == action_type } %>
      <label class="gate-checkbox">
        <input type="checkbox"
               name="role[gates][<%= action_type %>]"
               value="1"
               <%= "checked" if gate&.enabled? %>>
        <span class="gate-checkbox__label"><%= action_type.humanize %></span>
        <span class="gate-checkbox__description"><%= gate_description(action_type) %></span>
      </label>
    <% end %>
  </div>
</fieldset>
