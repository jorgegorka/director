<% if agent.pending_approval? %>
  <div class="approval-banner">
    <div class="approval-banner__icon">
      <span class="icon icon--warning"></span>
    </div>
    <div class="approval-banner__content">
      <h3 class="approval-banner__title">Pending Approval</h3>
      <p class="approval-banner__reason"><%= agent.pause_reason %></p>
    </div>
    <div class="approval-banner__actions">
      <%= button_to "Approve", approve_agent_path(agent), class: "btn btn--primary btn--sm",
            data: { turbo_confirm: "Approve #{agent.name} to continue?" } %>
      <%= button_to "Reject", reject_agent_path(agent), class: "btn btn--danger btn--sm",
            data: { turbo_confirm: "Reject #{agent.name}'s pending action?" } %>
    </div>
  </div>
<% end %>
