<div class="agent-card">
  <div class="agent-card__header">
    <%= link_to agent.name, agent, class: "agent-card__name" %>
    <%= agent_status_badge(agent) %>
  </div>
  <div class="agent-card__meta">
    <span class="agent-card__adapter"><%= adapter_type_label(agent) %></span>
    <% if agent.description.present? %>
      <p class="agent-card__description"><%= truncate(agent.description, length: 120) %></p>
    <% end %>
  </div>
  <div class="agent-card__footer">
    <% if agent.skills.any? %>
      <div class="agent-card__skill-tags">
        <% agent.skills.first(3).each do |skill| %>
          <span class="agent-card__skill-tag"><%= skill.name %></span>
        <% end %>
        <% overflow = agent.skills.size - 3 %>
        <% if overflow > 0 %>
          <span class="agent-card__skill-overflow">+<%= overflow %> more</span>
        <% end %>
      </div>
    <% end %>
    <% if agent.roles.any? %>
      <span class="agent-card__roles"><%= pluralize(agent.roles.size, "role") %></span>
    <% end %>
  </div>
</div>
