<%#
  Wraps a trigger button + a modal dialog containing the task form.

  Locals:
    task          — Task instance (new or persisted)
    title         — modal heading (e.g. "New task", "Edit task")
    trigger_label — button text
    trigger_class — optional css class for the trigger button
%>
<%
  trigger_class = local_assigns.fetch(:trigger_class, "btn btn--primary btn--sm")
%>
<div data-controller="modal" class="task-modal">
  <button type="button" class="<%= trigger_class %>" data-action="modal#open">
    <%= trigger_label %>
  </button>
  <%= render "shared/modal", title: title, size: "lg" do %>
    <%= render "tasks/form", task: task %>
  <% end %>
</div>
