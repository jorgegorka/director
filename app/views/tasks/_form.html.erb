<%= form_with(model: task, class: "form") do |f| %>
  <% if task.errors.any? %>
    <div class="form__errors" role="alert">
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "Title" %>
    <%= f.text_field :title, required: true, autofocus: true, placeholder: "e.g. Implement user authentication, Review Q3 budget" %>
  </div>

  <div class="form__field">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, rows: 4, placeholder: "What needs to be done and any relevant context" %>
  </div>

  <fieldset class="form__fieldset">
    <legend>Assignment & Priority</legend>

    <div class="form__field">
      <%= f.label :creator_id, "Create as" %>
      <%= f.select :creator_id, options_for_role_select, { include_blank: "Select a role" }, { class: "form__select" } %>
      <p class="form__hint">The role that owns this task.</p>
    </div>

    <div class="form__field">
      <%= f.label :assignee_id, "Assignee" %>
      <%= f.select :assignee_id, options_for_role_select, { include_blank: "Unassigned" }, { class: "form__select" } %>
      <p class="form__hint">The role responsible for completing this task.</p>
    </div>

    <div class="form__field">
      <%= f.label :priority, "Priority" %>
      <%= f.select :priority, options_for_task_priority, {}, { class: "form__select" } %>
    </div>
  </fieldset>

  <fieldset class="form__fieldset">
    <legend>Planning</legend>

    <div class="form__field">
      <%= f.label :goal_id, "Goal" %>
      <%= f.select :goal_id, options_for_goal_select, { include_blank: "No goal" }, { class: "form__select" } %>
      <p class="form__hint">Link this task to a strategic goal.</p>
    </div>

    <div class="form__field">
      <%= f.label :due_at, "Due date" %>
      <%= f.datetime_local_field :due_at %>
      <p class="form__hint">When this task should be completed.</p>
    </div>

    <% if task.persisted? %>
      <div class="form__field">
        <%= f.label :status, "Status" %>
        <%= f.select :status, options_for_task_status, {}, { class: "form__select" } %>
      </div>
    <% end %>
  </fieldset>

  <div class="form__actions">
    <%= f.submit task.persisted? ? "Update Task" : "Create Task", class: "btn btn--primary" %>
    <%= link_to "Cancel", task.persisted? ? task_path(task) : tasks_path, class: "btn btn--ghost" %>
  </div>
<% end %>
