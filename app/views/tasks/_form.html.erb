<%#
  Linear-style task form. Rendered inside a <dialog> via a Turbo Frame lazy
  load (see tasks/_form_modal.html.erb), and also served standalone at
  /tasks/new and /tasks/:id/edit. Submits with turbo_frame: "_top" so the
  create/update redirect escapes the frame cleanly.
%>
<% cancel = local_assigns.fetch(:cancel, :modal) %>
<%= form_with(model: task, class: "task-form", data: { turbo_frame: "_top" }) do |f| %>
  <% if task.errors.any? %>
    <div class="form__errors" role="alert">
      <p><strong><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</strong></p>
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.text_field :title,
        class: "task-form__title",
        required: true,
        autofocus: true,
        placeholder: "Task title" %>

  <%= f.text_area :description,
        class: "task-form__description",
        rows: 3,
        placeholder: "Add a description…" %>

  <%
    pills = [
      { attribute: :assignee_id,    icon: :assignee,    placeholder: "Unassigned",   options: options_for_role_select,              searchable: true },
      { attribute: :creator_id,     icon: :creator,     placeholder: "No owner",     options: options_for_role_select,              searchable: true },
      { attribute: :priority,       icon: :priority,    placeholder: "No priority",  options: options_for_task_priority },
      { attribute: :parent_task_id, icon: :parent_task, placeholder: "No parent",    options: options_for_parent_task_select(task), searchable: true }
    ]
  %>
  <div class="task-form__pills">
    <% pills.each do |pill| %>
      <%= render "tasks/pill",
            form: f,
            attribute: pill[:attribute],
            icon: task_pill_icon(pill[:icon]),
            placeholder: pill[:placeholder],
            options: pill[:options],
            searchable: pill.fetch(:searchable, false) %>
    <% end %>

    <%= render "tasks/due_date_pill", form: f %>
  </div>

  <% if task.persisted? %>
    <div class="task-form__status">
      <span class="task-form__status-label">Status</span>
      <%= f.select :status, options_for_task_status, {}, class: "form__select" %>
    </div>
  <% end %>

  <div class="task-form__footer">
    <% if cancel == :modal %>
      <button type="button" class="btn btn--ghost" data-action="modal#close">Cancel</button>
    <% else %>
      <%= link_to "Cancel", cancel, class: "btn btn--ghost" %>
    <% end %>
    <%= f.submit task.persisted? ? "Update task" : "Create task", class: "btn btn--primary" %>
  </div>
<% end %>
