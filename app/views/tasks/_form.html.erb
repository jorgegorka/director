<%= form_with(model: task, class: "form") do |f| %>
  <% if task.errors.any? %>
    <div class="form__errors">
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "Title" %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="form__field">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, rows: 4 %>
  </div>

  <div class="form__field">
    <%= f.label :priority, "Priority" %>
    <%= f.select :priority, options_for_task_priority, {}, { class: "form__select" } %>
  </div>

  <div class="form__field">
    <%= f.label :assignee_id, "Assignee" %>
    <%= f.select :assignee_id, options_for_agent_select, { include_blank: "Unassigned" }, { class: "form__select" } %>
  </div>

  <div class="form__field">
    <%= f.label :goal_id, "Goal" %>
    <%= f.select :goal_id, options_for_goal_select, { include_blank: "No goal" }, { class: "form__select" } %>
  </div>

  <div class="form__field">
    <%= f.label :due_at, "Due Date" %>
    <%= f.datetime_local_field :due_at %>
  </div>

  <% if task.persisted? %>
    <div class="form__field">
      <%= f.label :status, "Status" %>
      <%= f.select :status, options_for_task_status, {}, { class: "form__select" } %>
    </div>
  <% end %>

  <div class="form__actions">
    <%= f.submit task.persisted? ? "Update Task" : "Create Task", class: "btn btn--primary" %>
    <%= link_to "Cancel", task.persisted? ? task_path(task) : tasks_path, class: "btn btn--ghost" %>
  </div>
<% end %>
