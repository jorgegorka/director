<%#
  Linear-style task form. Used inside a modal by default (locals[:cancel]
  falls through to modal#close) and as a standalone page for deep-link
  routes /tasks/new and /tasks/:id/edit (locals[:cancel] set to a URL).
%>
<% cancel = local_assigns.fetch(:cancel, :modal) %>
<%= form_with(model: task, class: "task-form") do |f| %>
  <% if task.errors.any? %>
    <div class="form__errors">
      <p><strong><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</strong></p>
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.text_field :title,
        class: "task-form__title",
        required: true,
        autofocus: true,
        placeholder: "Task title" %>

  <%= f.text_area :description,
        class: "task-form__description",
        rows: 3,
        placeholder: "Add a description…" %>

  <div class="task-form__pills">
    <%= render "tasks/pill",
          form: f,
          attribute: :assignee_id,
          icon: task_pill_icon(:assignee),
          placeholder: "Unassigned",
          options: options_for_role_select,
          searchable: true %>

    <%= render "tasks/pill",
          form: f,
          attribute: :creator_id,
          icon: task_pill_icon(:creator),
          placeholder: "No owner",
          options: options_for_role_select,
          searchable: true %>

    <%= render "tasks/pill",
          form: f,
          attribute: :priority,
          icon: task_pill_icon(:priority),
          placeholder: "No priority",
          options: options_for_task_priority %>

    <%= render "tasks/pill",
          form: f,
          attribute: :parent_task_id,
          icon: task_pill_icon(:parent_task),
          placeholder: "No parent",
          options: options_for_parent_task_select(task),
          searchable: true %>

    <%= render "tasks/due_date_pill", form: f %>
  </div>

  <% if task.persisted? %>
    <div class="task-form__status">
      <span class="task-form__status-label">Status</span>
      <%= f.select :status, options_for_task_status, {}, class: "form__select" %>
    </div>
  <% end %>

  <div class="task-form__footer">
    <% if cancel == :modal %>
      <button type="button" class="btn btn--ghost" data-action="modal#close">Cancel</button>
    <% else %>
      <%= link_to "Cancel", cancel, class: "btn btn--ghost" %>
    <% end %>
    <%= f.submit task.persisted? ? "Update task" : "Create task", class: "btn btn--primary" %>
  </div>
<% end %>
