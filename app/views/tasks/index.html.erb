<% content_for(:title, "Tasks") %>

<section class="tasks-page">
  <div class="tasks-page__header">
    <h1>Tasks</h1>
    <%= render "tasks/modal",
          task: Current.project.tasks.new(priority: :medium),
          title: "New task",
          trigger_label: "New Task",
          trigger_class: "btn btn--primary btn--sm" %>
  </div>

  <% if @tasks.any? %>
    <div class="task-list">
      <% @tasks.each do |task| %>
        <%= render partial: "tasks/task", locals: { task: task } %>
      <% end %>
    </div>
  <% else %>
    <div class="tasks-page__empty">
      <p>No tasks yet. Create your first task to get started.</p>
      <%= render "tasks/modal",
            task: Current.project.tasks.new(priority: :medium),
            title: "New task",
            trigger_label: "Create a task",
            trigger_class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
