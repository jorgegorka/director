<% content_for(:title, "Tasks") %>

<section class="tasks-page">
  <div class="tasks-page__header">
    <h1>Tasks</h1>
    <%= link_to "New Task", new_task_path, class: "btn btn--primary btn--sm" %>
  </div>

  <% if @tasks.any? %>
    <div class="task-list">
      <% @tasks.each do |task| %>
        <%= render partial: "tasks/task", locals: { task: task } %>
      <% end %>
    </div>
  <% else %>
    <div class="tasks-page__empty">
      <p>No tasks yet. Create your first task to get started.</p>
      <%= link_to "Create a task", new_task_path, class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
