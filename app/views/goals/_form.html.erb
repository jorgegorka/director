<%= form_with(model: goal, class: "form") do |f| %>
  <% if goal.errors.any? %>
    <div class="form__errors">
      <ul>
        <% goal.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "Title" %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="form__field">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, rows: 4 %>
  </div>

  <div class="form__field">
    <%= f.label :parent_id, "Parent Goal" %>
    <%= f.select :parent_id, options_for_goal_select(exclude: goal), { include_blank: "None (top-level mission)" }, { class: "form__select" } %>
  </div>

  <div class="form__field">
    <%= f.label :position, "Position (ordering)" %>
    <%= f.number_field :position, min: 0, value: goal.position || 0 %>
  </div>

  <div class="form__field">
    <%= f.label :role_id, "Assigned Role" %>
    <%= f.select :role_id,
          Current.company.roles.active.order(:title).map { |r| [r.title, r.id] },
          { include_blank: "No role assigned" },
          { class: "form__select" } %>
    <p class="form__hint">The role responsible for this goal. Completed tasks under this goal will be evaluated against it.</p>
  </div>

  <div class="form__actions">
    <%= f.submit goal.persisted? ? "Update Goal" : "Create Goal", class: "btn btn--primary" %>
    <%= link_to "Cancel", goal.persisted? ? goal_path(goal) : goals_path, class: "btn btn--ghost" %>
  </div>
<% end %>
