<% content_for(:title, @goal.title) %>

<section class="goal-detail">
  <div class="goal-detail__header">
    <div class="goal-detail__header-top">
      <div>
        <h1 class="goal-detail__title"><%= @goal.title %></h1>
      </div>
      <div class="goal-detail__actions">
        <%= link_to "Edit", edit_goal_path(@goal), class: "btn btn--ghost btn--sm" %>
        <%= button_to "Delete", @goal, method: :delete, class: "btn btn--ghost btn--sm goal-detail__delete",
              data: { turbo_confirm: "Delete '#{@goal.title}'?" } %>
      </div>
    </div>

    <% percentage = @goal.completion_percentage %>
    <div class="goal-detail__progress-card">
      <div class="goal-detail__progress-info">
        <span class="goal-detail__progress-label">Progress</span>
        <span class="goal-detail__progress-value"><%= percentage %>%</span>
      </div>
      <%= render "shared/progress_bar", percentage: percentage, large: true %>
      <div class="goal-detail__progress-stats">
        <span><%= percentage %>% complete &middot; <%= @detail.tasks.count { |t| t.status == "completed" } %> of <%= @detail.tasks.size %> tasks done</span>
        <% if @detail.any_evaluations? %>
          <span class="goal-detail__eval-stats">&middot; <%= @detail.eval_pass_count %>/<%= @detail.eval_total %> evaluations passed (<%= @detail.eval_pass_rate %>%)</span>
        <% end %>
      </div>
    </div>
    <% if @goal.role.present? %>
      <div class="goal-detail__role">
        <span>Assigned to: <%= link_to @goal.role.title, role_path(@goal.role) %></span>
      </div>
    <% end %>
  </div>

  <div class="goal-detail__body">
    <% if @goal.description.present? %>
      <div class="goal-detail__description">
        <p><%= @goal.description %></p>
      </div>
    <% end %>

    <div class="goal-detail__section">
      <div class="goal-detail__section-header">
        <h2>Tasks <span class="goal-detail__count"><%= @detail.tasks.size %></span></h2>
        <%= link_to "+ Create task", new_task_path(goal_id: @goal.id), class: "btn btn--primary btn--sm" %>
      </div>
      <% if @detail.any_tasks? %>
        <div class="task-list">
          <% @detail.tasks.each do |task| %>
            <%= render partial: "tasks/task", locals: { task: task } %>
          <% end %>
        </div>
      <% else %>
        <div class="goal-detail__empty">
          <p>No tasks yet. Create a task to start working toward this goal.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
