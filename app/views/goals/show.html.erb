<% content_for(:title, @goal.title) %>

<section class="goal-detail">
  <div class="goal-detail__header">
    <div class="goal-detail__header-top">
      <div>
        <nav class="goal-detail__breadcrumb">
          <% @goal.ancestry_chain[0...-1].each do |ancestor| %>
            <%= link_to ancestor.title, goal_path(ancestor) %> <span class="goal-detail__sep">/</span>
          <% end %>
        </nav>

        <% if @goal.mission? %>
          <span class="goal-tree__label goal-tree__label--mission">Mission</span>
        <% end %>
        <h1 class="goal-detail__title"><%= @goal.title %></h1>
      </div>
      <div class="goal-detail__actions">
        <%= link_to "Edit", edit_goal_path(@goal), class: "btn btn--ghost btn--sm" %>
        <%= button_to "Delete", @goal, method: :delete, class: "btn btn--ghost btn--sm goal-detail__delete",
              data: { turbo_confirm: "Delete '#{@goal.title}'? Child goals will also be deleted." } %>
      </div>
    </div>

    <% percentage = @goal.progress_percentage %>
    <div class="goal-detail__progress-card">
      <div class="goal-detail__progress-info">
        <span class="goal-detail__progress-label">Progress</span>
        <span class="goal-detail__progress-value"><%= percentage %>%</span>
      </div>
      <%= render "shared/progress_bar", percentage: percentage, large: true %>
      <div class="goal-detail__progress-stats">
        <span><%= percentage %>% complete &middot; <%= @tasks.count { |t| t.status == "completed" } %> of <%= @tasks.size %> tasks done</span>
        <% if @eval_total > 0 %>
          <span class="goal-detail__eval-stats">&middot; <%= @eval_pass_count %>/<%= @eval_total %> evaluations passed (<%= (@eval_pass_count.to_f / @eval_total * 100).round %>%)</span>
        <% end %>
      </div>
    </div>
    <% if @goal.agent.present? %>
      <div class="goal-detail__agent">
        <span>Assigned to: <%= link_to @goal.agent.name, agent_path(@goal.agent) %></span>
      </div>
    <% end %>
  </div>

  <div class="goal-detail__body">
    <% if @goal.description.present? %>
      <div class="goal-detail__description">
        <p><%= @goal.description %></p>
      </div>
    <% end %>

    <div class="goal-detail__section">
      <div class="goal-detail__section-header">
        <h2>Objectives <span class="goal-detail__count"><%= @children.size %></span></h2>
        <%= link_to "+ Add objective", new_goal_path(parent_id: @goal.id), class: "btn btn--ghost btn--sm" %>
      </div>
      <% if @children.any? %>
        <div class="goal-tree">
          <% @children.each do |child| %>
            <%= render partial: "goals/goal_tree_node", locals: { goal: child, depth: 0 } %>
          <% end %>
        </div>
      <% else %>
        <div class="goal-detail__empty">
          <p>No objectives yet. Break this goal into smaller objectives to track progress.</p>
        </div>
      <% end %>
    </div>

    <div class="goal-detail__section">
      <div class="goal-detail__section-header">
        <h2>Tasks <span class="goal-detail__count"><%= @tasks.size %></span></h2>
        <%= link_to "+ Create task", new_task_path(goal_id: @goal.id), class: "btn btn--primary btn--sm" %>
      </div>
      <% if @tasks.any? %>
        <div class="task-list">
          <% @tasks.each do |task| %>
            <%= render partial: "tasks/task", locals: { task: task } %>
          <% end %>
        </div>
      <% else %>
        <div class="goal-detail__empty">
          <p>No tasks yet. Create a task to start working toward this goal.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
