<div class="auth-card">
  <h1>Create your account</h1>

  <% if @user.errors.any? %>
    <div class="flash flash--alert">
      <ul class="error-list">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: @user, url: registration_path) do |form| %>
    <div class="field">
      <%= form.label :email_address, "Email address" %>
      <%= form.email_field :email_address, autofocus: true, autocomplete: "email",
            required: true, placeholder: "you@example.com" %>
    </div>

    <div class="field">
      <%= form.label :password %>
      <%= form.password_field :password, autocomplete: "new-password",
            required: true, placeholder: "At least 12 characters" %>
    </div>

    <div class="field">
      <%= form.label :password_confirmation, "Confirm password" %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password",
            required: true, placeholder: "Repeat your password" %>
    </div>

    <div class="field">
      <%= form.submit "Create account", class: "btn btn--primary btn--full" %>
    </div>
  <% end %>

  <p class="auth-footer">
    Already have an account?
    <%= link_to "Log in", new_session_path %>
  </p>
</div>
