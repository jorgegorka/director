<% content_for(:title, @agent_hook.name.presence || "Hook Detail") %>

<section class="hook-detail">
  <div class="hook-detail__header">
    <div>
      <h1><%= @agent_hook.name.presence || "Unnamed Hook" %></h1>
      <p class="hook-detail__breadcrumb">
        <%= link_to @agent.name, @agent %> &rsaquo;
        <%= link_to "Hooks", agent_agent_hooks_path(@agent) %> &rsaquo;
        <%= @agent_hook.name.presence || "Hook" %>
      </p>
    </div>
    <div class="hook-detail__actions">
      <%= link_to "Edit", edit_agent_agent_hook_path(@agent, @agent_hook), class: "btn btn--ghost btn--sm" %>
      <%= button_to "Delete", agent_agent_hook_path(@agent, @agent_hook), method: :delete, class: "btn btn--ghost btn--sm hook-detail__delete",
            data: { turbo_confirm: "Delete this hook? This cannot be undone." } %>
    </div>
  </div>

  <div class="hook-detail__body">
    <div class="hook-detail__section">
      <h2>Configuration</h2>
      <dl class="hook-detail__config">
        <div class="hook-detail__config-row">
          <dt>Status</dt>
          <dd><%= hook_status_badge(@agent_hook) %></dd>
        </div>
        <div class="hook-detail__config-row">
          <dt>Lifecycle Event</dt>
          <dd><%= lifecycle_event_label(@agent_hook.lifecycle_event) %></dd>
        </div>
        <div class="hook-detail__config-row">
          <dt>Action Type</dt>
          <dd><%= action_type_label(@agent_hook.action_type) %></dd>
        </div>
        <div class="hook-detail__config-row">
          <dt>Position</dt>
          <dd><%= @agent_hook.position %></dd>
        </div>
      </dl>
    </div>

    <div class="hook-detail__section">
      <h2>Action Configuration</h2>
      <dl class="hook-detail__config">
        <% if @agent_hook.trigger_agent? %>
          <div class="hook-detail__config-row">
            <dt>Target Agent</dt>
            <dd>
              <% if @agent_hook.target_agent %>
                <%= link_to @agent_hook.target_agent.name, @agent_hook.target_agent %>
              <% else %>
                <span class="hook-detail__missing">Agent not found</span>
              <% end %>
            </dd>
          </div>
          <% if @agent_hook.action_config&.dig("prompt") %>
            <div class="hook-detail__config-row">
              <dt>Prompt</dt>
              <dd><%= @agent_hook.action_config["prompt"] %></dd>
            </div>
          <% end %>
        <% elsif @agent_hook.webhook? %>
          <div class="hook-detail__config-row">
            <dt>URL</dt>
            <dd><code><%= @agent_hook.action_config&.dig("url") %></code></dd>
          </div>
          <% if @agent_hook.action_config&.dig("headers").present? %>
            <div class="hook-detail__config-row">
              <dt>Headers</dt>
              <dd>
                <% @agent_hook.action_config["headers"].each do |key, value| %>
                  <code><%= key %>: <%= key.downcase.include?("auth") ? "••••••••" : value %></code><br>
                <% end %>
              </dd>
            </div>
          <% end %>
        <% end %>
      </dl>
    </div>

    <div class="hook-detail__section">
      <h2>Executions (<%= @executions_count %>)</h2>
      <% if @recent_executions.any? %>
        <table class="table">
          <thead>
            <tr>
              <th>Status</th>
              <th>Task</th>
              <th>Duration</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_executions.each do |execution| %>
              <tr>
                <td><%= hook_execution_status_badge(execution) %></td>
                <td><%= link_to execution.task.title, execution.task %></td>
                <td><%= execution.duration_seconds ? "#{execution.duration_seconds}s" : "-" %></td>
                <td><%= time_ago_in_words(execution.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @executions_count > 5 %>
          <p class="hook-detail__more-note"><%= @executions_count - 5 %> more executions not shown.</p>
        <% end %>
      <% else %>
        <p class="hook-detail__empty-note">No executions yet. This hook will fire when a matching task lifecycle event occurs.</p>
      <% end %>
    </div>
  </div>
</section>
