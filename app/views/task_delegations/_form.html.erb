<% targets = delegation_targets_for(task) %>
<% if targets.any? %>
  <div class="task-action-form">
    <h3>Delegate to Subordinate</h3>
    <%= form_with(url: delegate_task_path(task), class: "form form--inline") do |f| %>
      <div class="form__field form__field--inline">
        <%= f.select :agent_id, targets, { prompt: "Select subordinate agent..." }, required: true %>
        <%= f.text_field :reason, placeholder: "Reason (optional)" %>
        <%= f.submit "Delegate", class: "btn btn--ghost btn--sm" %>
      </div>
    <% end %>
  </div>
<% end %>
