<% content_for(:title, "Run ##{@agent_run.id} - #{@agent.name}") %>

<%= turbo_stream_from "agent_run_#{@agent_run.id}" %>

<section class="agent-run-detail">
  <header class="agent-run-detail__header">
    <div>
      <h1>Run #<%= @agent_run.id %></h1>
      <p class="agent-run-detail__subtitle">
        <%= link_to @agent.name, agent_path(@agent) %> &middot;
        <%= agent_run_status_badge(@agent_run) %>
      </p>
    </div>
    <div class="agent-run-detail__actions">
      <%= link_to "All Runs", agent_agent_runs_path(@agent), class: "btn btn--ghost btn--sm" %>
      <% unless @agent_run.terminal? %>
        <%= button_to "Cancel Run", cancel_agent_agent_run_path(@agent, @agent_run),
              method: :post,
              class: "btn btn--danger btn--sm" %>
      <% end %>
    </div>
  </header>

  <div class="agent-run-detail__meta">
    <dl class="agent-run-detail__kv">
      <div class="agent-run-detail__kv-row">
        <dt>Trigger</dt>
        <dd><%= @agent_run.trigger_type&.humanize || "---" %></dd>
      </div>
      <div class="agent-run-detail__kv-row">
        <dt>Duration</dt>
        <dd><%= agent_run_duration(@agent_run) %></dd>
      </div>
      <div class="agent-run-detail__kv-row">
        <dt>Cost</dt>
        <dd><%= @agent_run.cost_cents ? format_cents_as_dollars(@agent_run.cost_cents) : "---" %></dd>
      </div>
      <% if @agent_run.task.present? %>
        <div class="agent-run-detail__kv-row">
          <dt>Task</dt>
          <dd><%= link_to @agent_run.task.title, task_path(@agent_run.task) %></dd>
        </div>
      <% end %>
      <% if @agent_run.error_message.present? %>
        <div class="agent-run-detail__kv-row agent-run-detail__kv-row--error">
          <dt>Error</dt>
          <dd><%= @agent_run.error_message %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="agent-run-output" id="agent-run-output-container">
    <h2 class="agent-run-output__title">Output</h2>
    <div class="agent-run-output__stream" id="agent-run-output">
      <%# Render existing log lines for completed/in-progress runs %>
      <% if @agent_run.log_output.present? %>
        <% @agent_run.log_output.split("\n").each do |line| %>
          <%= render "agent_runs/log_line", text: line + "\n" %>
        <% end %>
      <% end %>
      <%# New lines will be appended here by Turbo Stream broadcasts %>
    </div>
    <% if @agent_run.running? || @agent_run.queued? %>
      <div class="agent-run-output__live-indicator" id="agent-run-live-indicator">
        <span class="agent-run-output__pulse"></span> Live
      </div>
    <% else %>
      <div id="agent-run-live-indicator"></div>
    <% end %>
  </div>
</section>
