<%
  # Detect stream-JSON tool-use events
  tool_name = nil
  is_tool_use = false
  begin
    if text.present? && text.strip.start_with?("{")
      event = JSON.parse(text.strip)
      if event["type"] == "content_block_start" && event.dig("content_block", "type") == "tool_use"
        is_tool_use = true
        tool_name = event.dig("content_block", "name")
      end
    end
  rescue JSON::ParserError
    # Not JSON, render as plain text
  end
%>
<% if is_tool_use && tool_name.present? %>
  <div class="agent-run-output__line agent-run-output__line--tool">
    <span class="agent-run-output__tool-indicator"><%= tool_name %></span>
  </div>
<% else %>
  <div class="agent-run-output__line"><%= text %></div>
<% end %>
