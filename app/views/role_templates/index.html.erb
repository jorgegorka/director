<% content_for(:title, "Role Templates") %>

<section class="templates-page">
  <div class="templates-page__header">
    <h1>Role Templates</h1>
    <p class="templates-page__subtitle">Apply a department template to quickly set up a team with predefined roles, skills, and hierarchy.</p>
  </div>

  <div class="templates-grid">
    <% @templates.each do |template| %>
      <%= link_to role_template_path(template.key), class: "template-card" do %>
        <h2 class="template-card__name"><%= template.name %></h2>
        <p class="template-card__description"><%= template.description %></p>
        <div class="template-card__meta">
          <span class="template-card__role-count"><%= pluralize(template.roles.size, "role") %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
