<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Director - AI orchestration made easy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Director">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="author" content="Mario & Jorge Alvarez" />
    <meta name="view-transition" content="same-origin" />
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="app-header">
      <div class="app-header__brand">
        <%= link_to "Director", root_path, class: "app-header__logo" %>
      </div>

      <nav class="app-header__nav">
        <% if Current.user %>
          <%= render "layouts/company_switcher" %>
          <% if Current.company %>
            <%= link_to "Dashboard", root_path, class: "nav__link #{"nav__link--active" if controller_name == "dashboard"}" %>
            <%= link_to "Roles", roles_path, class: "nav__link #{"nav__link--active" if controller_name == "roles"}" %>
            <%= link_to "Tasks", tasks_path, class: "nav__link #{"nav__link--active" if controller_name == "tasks"}" %>
            <%= link_to "Skills", skills_path, class: "nav__link #{"nav__link--active" if controller_name == "skills"}" %>
            <%= link_to "Audit Log", audit_logs_path, class: "nav__link #{"nav__link--active" if controller_name == "audit_logs"}" %>
            <%= render "notifications/dropdown" %>
            <%= button_to "Emergency Stop", emergency_stop_company_path(Current.company),
                  method: :post,
                  class: "btn btn--sm emergency-stop-btn",
                  data: { turbo_confirm: "EMERGENCY STOP: This will pause ALL active roles in #{Current.company.name}. Continue?" } %>
          <% end %>
          <span class="app-header__user"><%= Current.user.email_address %></span>
          <%= link_to "Settings", settings_path, class: "btn btn--ghost btn--sm" %>
          <%= button_to "Log out", session_path, method: :delete,
                class: "btn btn--ghost btn--sm" %>
        <% else %>
          <%= link_to "Log in", new_session_path, class: "btn btn--ghost btn--sm" %>
          <%= link_to "Sign up", new_registration_path, class: "btn btn--primary btn--sm" %>
        <% end %>
      </nav>
    </header>

    <% if notice %>
      <div class="flash flash--notice" role="status" data-controller="flash"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash flash--alert" role="alert" data-controller="flash"><%= alert %></div>
    <% end %>

    <main class="app-main">
      <%= yield %>
    </main>
  </body>
</html>
