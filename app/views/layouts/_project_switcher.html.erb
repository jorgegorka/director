<div class="project-switcher" data-controller="dropdown">
  <button class="project-switcher__trigger" data-action="click->dropdown#toggle" data-dropdown-target="trigger" type="button">
    <span class="project-switcher__name"><%= current_project&.name || "No Project" %></span>
    <svg class="project-switcher__caret" viewBox="0 0 10 6" fill="none" aria-hidden="true">
      <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="project-switcher__menu" data-dropdown-target="menu" hidden>
    <div class="project-switcher__label">Projects</div>
    <% Current.user.projects.each do |project| %>
      <div class="project-switcher__item">
        <% if project == current_project %>
          <span class="project-switcher__current">
            <svg class="project-switcher__check" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <%= project.name %>
          </span>
        <% else %>
          <%= button_to project_switch_path(project), method: :post, class: "project-switcher__link" do %>
            <span class="project-switcher__check project-switcher__check--hidden" aria-hidden="true"></span>
            <%= project.name %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <div class="project-switcher__divider"></div>
    <% if current_project %>
      <%= link_to "Project Settings", edit_project_path(current_project), class: "project-switcher__action" %>
    <% end %>
    <%= link_to "New Project", new_project_path, class: "project-switcher__action" %>

    <div class="project-switcher__divider"></div>
    <%= link_to "Account Settings", settings_path, class: "project-switcher__action" %>
    <%= button_to "Log out", session_path, method: :delete, class: "project-switcher__logout-btn", form_class: "project-switcher__logout-form" %>
  </div>
</div>
