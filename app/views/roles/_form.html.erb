<%= form_with(model: role, class: "form") do |f| %>
  <% if role.errors.any? %>
    <div class="form__errors" role="alert">
      <% role.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "Role title" %>
    <%= f.text_field :title, autofocus: true, required: true, placeholder: "e.g. CTO, Lead Developer, Research Analyst" %>
  </div>

  <div class="form__field">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, rows: 3, placeholder: "Brief description of this role's purpose" %>
  </div>

  <div class="form__field">
    <%= f.label :job_spec, "Job specification" %>
    <%= f.text_area :job_spec, rows: 6, placeholder: "Detailed job spec: responsibilities, skills, expected outputs..." %>
  </div>

  <div class="form__field">
    <%= f.label :parent_id, "Reports to" %>
    <%= f.select :parent_id,
          options_for_parent_select(role),
          { include_blank: "None (top-level role)" },
          { class: "form__select" } %>
  </div>

  <div class="form__actions">
    <%= f.submit class: "btn btn--primary" %>
  </div>
<% end %>
