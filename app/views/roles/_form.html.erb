<%= form_with(model: role, class: "form", data: { controller: "adapter-config" }) do |f| %>
  <% if role.errors.any? %>
    <div class="form__errors" role="alert">
      <% role.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :title, "Role title" %>
    <%= f.text_field :title, autofocus: true, required: true, placeholder: "e.g. CTO, Lead Developer, Research Analyst" %>
  </div>

  <div class="form__field">
    <%= f.label :role_category_id, "Category" %>
    <%= f.select :role_category_id,
          options_from_collection_for_select(@role_categories, :id, :name, role.role_category_id),
          { prompt: "Select category..." },
          { class: "form__select", required: true } %>
    <p class="form__hint">Determines behavioral guidance appended to the agent prompt.</p>
  </div>

  <div class="form__field">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, rows: 4, placeholder: "Brief description of this role's purpose" %>
  </div>

  <div class="form__field">
    <%= f.label :job_spec, "Job specification" %>
    <%= f.text_area :job_spec, rows: 10, placeholder: "Detailed job spec: responsibilities, skills, expected outputs..." %>
    <p class="form__hint">Will be used as prompt if present.</p>
  </div>

  <div class="form__field">
    <%= f.label :parent_id, "Reports to" %>
    <%= f.select :parent_id,
          options_for_parent_select(role),
          { include_blank: "None (top-level role)" },
          { class: "form__select" } %>
  </div>

  <div class="form__field">
    <%= f.label :working_directory, "Working directory" %>
    <%= f.text_field :working_directory, placeholder: "/path/to/project" %>
    <p class="form__hint">Filesystem path the agent operates in. Inherited from parent if blank.</p>
  </div>

  <div class="form__field">
    <%= f.label :adapter_type, "Connection type" %>
    <%= f.select :adapter_type, adapter_type_options, {}, {
      class: "form__select",
      data: { adapter_config_select: "", action: "change->adapter-config#toggle" }
    } %>
  </div>

  <!-- HTTP adapter config fields -->
  <fieldset class="form__fieldset" data-adapter-config-target="configGroup" data-adapter-type="http">
    <legend>HTTP API Configuration</legend>
    <div class="form__field">
      <%= label_tag "role_adapter_config_url", "Endpoint URL" %>
      <%= text_field_tag "role[adapter_config][url]",
            role.adapter_config&.dig("url"),
            placeholder: "https://api.example.com/role",
            id: "role_adapter_config_url" %>
    </div>
    <div class="form__field">
      <%= label_tag "role_adapter_config_method", "HTTP Method" %>
      <%= select_tag "role[adapter_config][method]",
            options_for_select([ "POST", "PUT" ], role.adapter_config&.dig("method") || "POST"),
            id: "role_adapter_config_method",
            class: "form__select" %>
    </div>
    <div class="form__field">
      <%= label_tag "role_adapter_config_auth_token", "Auth Token (optional)" %>
      <%= text_field_tag "role[adapter_config][auth_token]",
            role.adapter_config&.dig("auth_token"),
            placeholder: "Bearer token for authentication",
            id: "role_adapter_config_auth_token" %>
    </div>
  </fieldset>

  <!-- Process adapter config fields -->
  <fieldset class="form__fieldset" data-adapter-config-target="configGroup" data-adapter-type="process">
    <legend>Shell Command Configuration</legend>
    <div class="form__field">
      <%= label_tag "role_adapter_config_command", "Command" %>
      <%= text_field_tag "role[adapter_config][command]",
            role.adapter_config&.dig("command"),
            placeholder: "/usr/local/bin/my-role.sh",
            id: "role_adapter_config_command" %>
    </div>
    <div class="form__field">
      <%= label_tag "role_adapter_config_working_directory", "Working Directory (optional)" %>
      <%= text_field_tag "role[adapter_config][working_directory]",
            role.adapter_config&.dig("working_directory"),
            placeholder: "/home/user/role",
            id: "role_adapter_config_working_directory" %>
    </div>
  </fieldset>

  <!-- Claude Local adapter config fields -->
  <% claude_provider = role.adapter_config&.dig("provider").presence || "anthropic" %>
  <fieldset class="form__fieldset" data-adapter-config-target="configGroup" data-adapter-type="claude_local">
    <legend>Claude Code Configuration</legend>

    <div class="form__field">
      <%= label_tag "role_adapter_config_provider", "Provider" %>
      <%= select_tag "role[adapter_config][provider]",
            options_for_select([
              [ "Anthropic (hosted API)", "anthropic" ],
              [ "Ollama (local)", "ollama" ]
            ], claude_provider),
            id: "role_adapter_config_provider",
            class: "form__select",
            data: { provider_select: "", action: "change->adapter-config#toggleProvider" } %>
    </div>

    <div data-provider-value="anthropic">
      <div class="form__field">
        <%= label_tag "role_adapter_config_model", "Model" %>
        <%= select_tag "role[adapter_config][model]",
              options_for_select(
                [ [ "Claude Sonnet 4", "claude-sonnet-4-20250514" ], [ "Claude Opus 4", "claude-opus-4-20250514" ] ],
                role.adapter_config&.dig("model")
              ),
              id: "role_adapter_config_model",
              class: "form__select" %>
      </div>
    </div>

    <div data-provider-value="ollama">
      <div class="form__field">
        <%= label_tag "role_adapter_config_base_url", "Ollama base URL" %>
        <%= text_field_tag "role[adapter_config][base_url]",
              role.adapter_config&.dig("base_url") || "http://localhost:11434",
              id: "role_adapter_config_base_url" %>
        <p class="form__hint">Anthropic-compatible endpoint exposed by your local Ollama server.</p>
      </div>
      <div class="form__field">
        <%= label_tag "role_adapter_config_model_ollama", "Model" %>
        <%= text_field_tag "role[adapter_config][model]",
              role.adapter_config&.dig("model"),
              placeholder: "e.g. qwen3-coder, glm-4.7:cloud",
              id: "role_adapter_config_model_ollama" %>
        <p class="form__hint">Any model you have pulled with <code>ollama pull</code>.</p>
      </div>
    </div>

    <div class="form__field">
      <%= label_tag "role_adapter_config_max_turns", "Max Turns (optional)" %>
      <%= number_field_tag "role[adapter_config][max_turns]",
            role.adapter_config&.dig("max_turns"),
            placeholder: "25",
            min: 1,
            id: "role_adapter_config_max_turns" %>
    </div>
  </fieldset>

  <!-- OpenCode adapter config fields -->
  <% opencode_provider = role.adapter_config&.dig("provider").presence || "default" %>
  <fieldset class="form__fieldset" data-adapter-config-target="configGroup" data-adapter-type="opencode">
    <legend>OpenCode Configuration</legend>

    <div class="form__field">
      <%= label_tag "role_adapter_config_opencode_provider", "Provider" %>
      <%= select_tag "role[adapter_config][provider]",
            options_for_select([
              [ "Hosted providers (Anthropic, OpenAI, etc.)", "default" ],
              [ "Ollama (local)", "ollama" ]
            ], opencode_provider),
            id: "role_adapter_config_opencode_provider",
            class: "form__select",
            data: { provider_select: "", action: "change->adapter-config#toggleProvider" } %>
    </div>

    <div data-provider-value="default">
      <div class="form__field">
        <%= label_tag "role_adapter_config_model", "Model" %>
        <%= select_tag "role[adapter_config][model]",
              options_for_select([
                [ "Claude Sonnet 4", "claude-sonnet-4-20250514" ],
                [ "Claude Opus 4", "claude-opus-4-20250514" ],
                [ "Claude 3.7 Sonnet", "claude-3-7-sonnet-20250219" ],
                [ "GPT-4o", "gpt-4o" ],
                [ "GPT-4.1", "gpt-4.1" ],
                [ "Gemini 2.5 Pro", "gemini-2.5-pro" ],
                [ "GLM 4.7", "glm-4.7" ],
                [ "GLM 5", "glm-5" ]
              ], role.adapter_config&.dig("model")),
              id: "role_adapter_config_model",
              class: "form__select" %>
      </div>
    </div>

    <div data-provider-value="ollama">
      <div class="form__field">
        <%= label_tag "role_adapter_config_opencode_base_url", "Ollama base URL" %>
        <%= text_field_tag "role[adapter_config][base_url]",
              role.adapter_config&.dig("base_url") || "http://localhost:11434/v1",
              id: "role_adapter_config_opencode_base_url" %>
        <p class="form__hint">OpenAI-compatible endpoint exposed by your local Ollama server (note the <code>/v1</code> suffix).</p>
      </div>
      <div class="form__field">
        <%= label_tag "role_adapter_config_opencode_model_ollama", "Model" %>
        <%= text_field_tag "role[adapter_config][model]",
              role.adapter_config&.dig("model"),
              placeholder: "e.g. openai/qwen3-coder",
              id: "role_adapter_config_opencode_model_ollama" %>
        <p class="form__hint">Prefix with the OpenCode provider (usually <code>openai/</code>) followed by your pulled Ollama model name.</p>
      </div>
    </div>

    <div class="form__field">
      <%= label_tag "role_adapter_config_max_turns", "Max Turns (optional)" %>
      <%= number_field_tag "role[adapter_config][max_turns]",
            role.adapter_config&.dig("max_turns"),
            placeholder: "25",
            min: 1,
            id: "role_adapter_config_max_turns" %>
    </div>
  </fieldset>

  <!-- Heartbeat Schedule Configuration -->
  <fieldset class="form__fieldset">
    <legend>Heartbeat Schedule</legend>
    <p class="form__hint">Configure how often this role wakes to check for work. The role will run on this schedule when enabled.</p>

    <div class="form__field">
      <%= f.label :heartbeat_enabled, "Enable scheduled heartbeat" %>
      <div class="form__toggle">
        <%= f.check_box :heartbeat_enabled, class: "form__checkbox" %>
        <span class="form__toggle-label">Role wakes on schedule</span>
      </div>
    </div>

    <div class="form__field">
      <%= f.label :heartbeat_interval, "Heartbeat interval" %>
      <%= f.select :heartbeat_interval,
            options_for_select(
              [
                ["Every 5 minutes", 5],
                ["Every 10 minutes", 10],
                ["Every 15 minutes", 15],
                ["Every 30 minutes", 30],
                ["Every hour", 60],
                ["Every 2 hours", 120],
                ["Every 6 hours", 360],
                ["Every 12 hours", 720],
                ["Every 24 hours", 1440]
              ],
              role.heartbeat_interval
            ),
            { include_blank: "Select interval..." },
            { class: "form__select" }
      %>
    </div>
  </fieldset>

  <!-- Budget Configuration -->
  <fieldset class="form__fieldset">
    <legend>Monthly Budget</legend>
    <p class="form__hint">Set a monthly spending limit for this role. When the limit is reached, the role will be automatically paused. Leave blank for unlimited.</p>

    <div class="form__field">
      <%= f.label :budget_dollars, "Monthly budget ($)" %>
      <div class="form__input-group">
        <span class="form__input-prefix">$</span>
        <%= f.number_field :budget_dollars,
              value: role.budget_cents ? (role.budget_cents / 100.0).round(2) : nil,
              step: 0.01,
              min: 0.01,
              placeholder: "e.g. 500.00",
              class: "form__input--with-prefix" %>
      </div>
    </div>
  </fieldset>

  <!-- Auto-Hire Configuration -->
  <fieldset class="form__fieldset">
    <legend>Automatic Hiring</legend>
    <p class="form__hint">When enabled, this role can hire subordinate roles from its department template without human approval.</p>

    <div class="form__field">
      <%= f.label :auto_hire_enabled, "Enable automatic hiring" %>
      <div class="form__toggle">
        <%= f.check_box :auto_hire_enabled, class: "form__checkbox" %>
        <span class="form__toggle-label">Role can hire subordinates automatically</span>
      </div>
    </div>
  </fieldset>

  <% unless role.new_record? %>
    <%= render "approval_gates/gate_fieldset", role: role %>
  <% end %>

  <div class="form__actions">
    <%= f.submit class: "btn btn--primary" %>
  </div>
<% end %>
