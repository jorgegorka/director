<% content_for(:title, "Roles") %>

<section class="roles-page <%= "roles-page--chart" if @view == "chart" %>">
  <div class="roles-page__header">
    <h1>Roles</h1>
    <div class="roles-page__actions">
      <div class="roles-page__tabs">
        <%= link_to "Org Chart", roles_path, class: "roles-page__tab #{"roles-page__tab--active" if @view == "chart"}" %>
        <%= link_to "List", roles_path(view: "list"), class: "roles-page__tab #{"roles-page__tab--active" if @view == "list"}" %>
      </div>
      <%= link_to "New Role", new_role_path, class: "btn btn--primary btn--sm" %>
    </div>
  </div>

  <% if @roles.any? %>
    <% if @view == "chart" %>
      <%= turbo_stream_from "org_chart_project_#{Current.project.id}" %>
      <div class="org-chart-container"
           data-controller="org-chart"
           data-org-chart-roles-value="<%= roles_tree_data(@root_roles, @roles_by_parent_id).to_json %>">
        <div class="org-chart-toolbar">
          <button type="button" class="btn btn--ghost btn--sm" data-action="org-chart#zoomIn" title="Zoom in">+</button>
          <button type="button" class="btn btn--ghost btn--sm" data-action="org-chart#zoomReset" title="Reset zoom">Reset</button>
          <button type="button" class="btn btn--ghost btn--sm" data-action="org-chart#zoomOut" title="Zoom out">&minus;</button>
        </div>
        <svg class="org-chart-svg" data-org-chart-target="svg">
        </svg>
        <div hidden data-org-chart-target="nodeTemplates">
          <% @roles.each do |role| %>
            <template data-role-id="<%= role.id %>">
              <%= render "roles/org_chart_node", role: role %>
            </template>
          <% end %>
        </div>
        <%# Goal (root task) creation modals — rendered outside SVG so <dialog> is not constrained by foreignObject %>
        <% @roles.each do |role| %>
          <div data-org-chart-target="goalModal" data-role-id="<%= role.id %>">
            <%= render "shared/modal", title: "New Goal for #{role.title}" do %>
              <%= form_with(model: Task.new, scope: :root_task, url: goals_path, class: "form") do |f| %>
                <%= f.hidden_field :creator_id, value: role.id %>

                <div class="form__field">
                  <%= f.label :title, "Title" %>
                  <%= f.text_field :title, required: true %>
                </div>

                <div class="form__field">
                  <%= f.label :description, "Description" %>
                  <%= f.text_area :description, rows: 3 %>
                </div>

                <div class="form__actions">
                  <%= f.submit "Create Goal", class: "btn btn--primary" %>
                  <button type="button" class="btn btn--ghost" data-action="modal#close">Cancel</button>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="roles-list">
        <% @roles.each do |role| %>
          <%= render partial: "roles/role", locals: { role: role } %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="roles-page__empty">
      <p>No roles yet. Create your first role or apply a department template to get started.</p>
      <%= link_to "Browse Templates", role_templates_path, class: "btn btn--primary" %>
      <%= link_to "Create a role", new_role_path, class: "btn btn--ghost" %>
    </div>
  <% end %>
</section>
