<div id="org-chart-node-<%= role.id %>"
     class="org-chart-node-card org-chart-node-card--<%= role.status %>"
     data-role-id="<%= role.id %>">
  <div class="org-chart-node-card__meta">
    <div class="org-chart-node-card__heading">
      <%= link_to role.title, role_path(role),
            class: "org-chart-node-card__title",
            data: { turbo_frame: "_top" } %>
      <span class="org-chart-node-card__dot" aria-label="<%= role.status.humanize %>"></span>
    </div>
    <div class="org-chart-node-card__tags">
      <% if role.role_category %>
        <span class="org-chart-node-card__category"><%= role.role_category.name.upcase %></span>
      <% end %>
      <span class="org-chart-node-card__status"><%= status_label_for(role) %></span>
    </div>
  </div>

  <div class="org-chart-node-card__actions">
    <% unless role.terminated? %>
      <% if role.idle? || role.error? %>
        <%= button_to "Run", role_activity_path(role), method: :post, class: "btn btn--success btn--xs", form: { data: { turbo_stream: true } } %>
      <% elsif role.running? %>
        <%= button_to "Pause", role_pause_path(role), method: :post, class: "btn btn--warning btn--xs", form: { data: { turbo_stream: true } } %>
      <% elsif role.paused? %>
        <%= button_to "Resume", role_pause_path(role), method: :delete, class: "btn btn--success btn--xs", form: { data: { turbo_stream: true } } %>
      <% elsif role.pending_approval? %>
        <%= button_to "Approve", role_approval_path(role), method: :post, class: "btn btn--success btn--xs", form: { data: { turbo_stream: true } } %>
      <% end %>
      <%= button_to "Stop", role_termination_path(role), method: :post, class: "btn btn--danger btn--xs",
            form: { data: { turbo_confirm: "Terminate #{role.title}?", turbo_stream: true } } %>
    <% end %>
    <button type="button" class="btn btn--ghost btn--xs" data-action="click->org-chart#openGoalModal" data-role-id="<%= role.id %>">+ Goal</button>
  </div>
</div>
