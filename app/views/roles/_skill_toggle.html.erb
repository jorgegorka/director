<% role_skill = role_skills_by_skill_id[skill.id] %>
<div class="skill-manager__item">
  <% if role_skill %>
    <%= button_to role_role_skill_path(role, role_skill),
          method: :delete,
          class: "skill-manager__toggle skill-manager__toggle--assigned",
          title: "Remove #{skill.name}" do %>
      <span class="skill-manager__checkbox">&#10003;</span>
      <span class="skill-manager__name"><%= skill.name %></span>
    <% end %>
  <% else %>
    <%= button_to role_role_skills_path(role),
          params: { skill_id: skill.id },
          class: "skill-manager__toggle",
          title: "Assign #{skill.name}" do %>
      <span class="skill-manager__checkbox"></span>
      <span class="skill-manager__name"><%= skill.name %></span>
    <% end %>
  <% end %>
</div>
