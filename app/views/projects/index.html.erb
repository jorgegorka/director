<% content_for(:title, "Your Projects") %>

<section class="projects-list">
  <div class="projects-list__header">
    <h1>Your Projects</h1>
    <%= link_to "New Project", new_project_path, class: "btn btn--primary btn--sm" %>
  </div>

  <% if @projects.any? %>
    <div class="projects-list__grid">
      <% @projects.each do |project| %>
        <div class="project-card glass <%= 'project-card--active' if project == current_project %>">
          <h2 class="project-card__name"><%= project.name %></h2>
          <p class="project-card__role">
            <%= project.memberships.find_by(user: Current.user)&.role&.capitalize %>
          </p>
          <div class="project-card__actions">
            <% if project == current_project %>
              <span class="project-card__badge">Active</span>
            <% else %>
              <%= button_to "Switch", project_switch_path(project), class: "btn btn--ghost btn--sm" %>
            <% end %>
            <%= link_to "Settings", edit_project_path(project), class: "btn btn--ghost btn--sm" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="projects-list__empty">
      <p>You don't have any projects yet.</p>
      <%= link_to "Create your first project", new_project_path, class: "btn btn--primary" %>
    </div>
  <% end %>
</section>
