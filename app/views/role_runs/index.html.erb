<% content_for(:title, "#{@role.title} - Runs") %>

<section class="role-runs">
  <header class="role-runs__header">
    <div>
      <h1>Execution Runs</h1>
      <p class="role-runs__subtitle"><%= link_to @role.title, role_path(@role) %></p>
    </div>
    <%= link_to "Back to Role", role_path(@role), class: "btn btn--ghost btn--sm" %>
  </header>

  <% if @role_runs.any? %>
    <table class="table role-runs__table">
      <thead>
        <tr>
          <th>Run</th>
          <th>Status</th>
          <th>Trigger</th>
          <th>Duration</th>
          <th>Cost</th>
          <th>Started</th>
        </tr>
      </thead>
      <tbody>
        <% @role_runs.each do |run| %>
          <tr>
            <td><%= link_to "##{run.id}", role_role_run_path(@role, run) %></td>
            <td><%= role_run_status_badge(run) %></td>
            <td><%= run.trigger_type&.humanize || "---" %></td>
            <td><%= role_run_duration(run) %></td>
            <td><%= run.cost_cents ? format_cents_as_dollars(run.cost_cents) : "---" %></td>
            <td><%= run.started_at ? time_ago_in_words(run.started_at) + " ago" : "Queued" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="role-runs__empty">No execution runs yet. Runs appear when the role is triggered.</p>
  <% end %>
</section>
