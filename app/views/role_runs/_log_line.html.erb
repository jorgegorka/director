<%
  event = nil
  begin
    stripped = text.strip if text.present?
    event = JSON.parse(stripped) if stripped&.start_with?("{")
  rescue JSON::ParserError
  end
%>

<% if event.nil? %>
  <div class="role-run-output__line"><%= text %></div>

<% elsif event["type"] == "assistant" %>
  <% content_parts = event.dig("message", "content") || [] %>
  <% content_parts.each do |part| %>
    <% if part["type"] == "text" && part["text"].present? %>
      <div class="role-run-output__line role-run-output__line--text">
        <%= simple_format(part["text"], {}, wrapper_tag: "span") %>
      </div>
    <% elsif part["type"] == "tool_use" %>
      <div class="role-run-output__line role-run-output__line--tool">
        <span class="role-run-output__tool-indicator"><%= part["name"] %></span>
      </div>
    <% end %>
  <% end %>

<% elsif event["type"] == "content_block_start" && event.dig("content_block", "type") == "tool_use" %>
  <div class="role-run-output__line role-run-output__line--tool">
    <span class="role-run-output__tool-indicator"><%= event.dig("content_block", "name") %></span>
  </div>

<% elsif event["type"] == "content_block_delta" && event.dig("delta", "type") == "text_delta" %>
  <% delta_text = event.dig("delta", "text") %>
  <% if delta_text.present? %>
    <div class="role-run-output__line"><%= delta_text %></div>
  <% end %>

<% elsif event["type"] == "result" && !event["is_error"] %>
  <% if event["total_cost_usd"].present? && event["total_cost_usd"] > 0 %>
    <div class="role-run-output__line role-run-output__line--result">
      Completed &middot; $<%= format("%.4f", event["total_cost_usd"]) %>
      <% if event["duration_api_ms"].present? && event["duration_api_ms"] > 0 %>
        &middot; <%= (event["duration_api_ms"] / 1000.0).round(1) %>s
      <% end %>
    </div>
  <% end %>

<% elsif event["type"] == "result" && event["is_error"] %>
  <div class="role-run-output__line role-run-output__line--error">
    Error: <%= event["result"] %>
  </div>

<%# Hidden events: system, hooks, content_block_stop, input_json_delta %>
<% end %>
