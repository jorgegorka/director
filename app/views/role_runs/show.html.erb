<% content_for(:title, "Run ##{@role_run.id} - #{@role.title}") %>

<%= turbo_stream_from "role_run_#{@role_run.id}" %>

<section class="role-run-detail">
  <header class="role-run-detail__header">
    <div>
      <h1>Run #<%= @role_run.id %></h1>
      <p class="role-run-detail__subtitle">
        <%= link_to @role.title, role_path(@role) %> &middot;
        <%= role_run_status_badge(@role_run) %>
      </p>
    </div>
    <div class="role-run-detail__actions">
      <%= link_to "All Runs", role_role_runs_path(@role), class: "btn btn--ghost btn--sm" %>
      <% unless @role_run.terminal? %>
        <%= button_to "Cancel Run", cancel_role_role_run_path(@role, @role_run),
              method: :post,
              class: "btn btn--danger btn--sm" %>
      <% end %>
    </div>
  </header>

  <div class="role-run-detail__meta">
    <dl class="role-run-detail__kv">
      <div class="role-run-detail__kv-row">
        <dt>Trigger</dt>
        <dd><%= @role_run.trigger_type&.humanize || "---" %></dd>
      </div>
      <div class="role-run-detail__kv-row">
        <dt>Duration</dt>
        <dd><%= role_run_duration(@role_run) %></dd>
      </div>
      <div class="role-run-detail__kv-row">
        <dt>Cost</dt>
        <dd><%= @role_run.cost_cents ? format_cents_as_dollars(@role_run.cost_cents) : "---" %></dd>
      </div>
      <% if @role_run.task.present? %>
        <div class="role-run-detail__kv-row">
          <dt>Task</dt>
          <dd><%= link_to @role_run.task.title, task_path(@role_run.task) %></dd>
        </div>
      <% end %>
      <% if @role_run.error_message.present? %>
        <div class="role-run-detail__kv-row role-run-detail__kv-row--error">
          <dt>Error</dt>
          <dd><%= @role_run.error_message %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="role-run-output" id="role-run-output-container">
    <h2 class="role-run-output__title">Output</h2>
    <div class="role-run-output__stream" id="role-run-output">
      <%# Render existing log lines for completed/in-progress runs %>
      <% if @role_run.log_output.present? %>
        <% @role_run.log_output.split("\n").each do |line| %>
          <%= render "role_runs/log_line", text: line + "\n" %>
        <% end %>
      <% end %>
      <%# New lines will be appended here by Turbo Stream broadcasts %>
    </div>
    <% if @role_run.running? || @role_run.queued? %>
      <div class="role-run-output__live-indicator" id="role-run-live-indicator">
        <span class="role-run-output__pulse"></span> Live
      </div>
    <% else %>
      <div id="role-run-live-indicator"></div>
    <% end %>
  </div>
</section>
