#!/usr/bin/env ruby
require_relative "../config/environment"

api_token = ENV["DIRECTOR_API_TOKEN"]

unless api_token.present?
  $stderr.puts "DIRECTOR_API_TOKEN environment variable is required"
  exit 1
end

role = Role.find_by(api_token: api_token)

unless role
  $stderr.puts "No role found for the provided API token"
  exit 1
end

# The tool scope determines which tool set this MCP instance exposes. The
# orchestrator runs in :orchestrator scope; each sub-agent subprocess passes
# its own scope (e.g. :sub_agent_review_task) via the MCP config env block.
scope = (ENV["DIRECTOR_TOOL_SCOPE"].presence || "orchestrator").to_sym

$stderr.puts "Director MCP server started for role: #{role.title} (#{role.company.name}) in #{scope} scope"

server = DirectorServer.new(role, tool_scope: scope)
server.run
